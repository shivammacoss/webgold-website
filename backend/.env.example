# Copy to .env and fill in
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/mysafe_gold

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30

# GoldAPI.io free tier — get a key at https://www.goldapi.io
GOLD_API_KEY=goldapi-demo
GOLD_API_URL=https://www.goldapi.io/api/XAU/INR

# Markup config (basis points; 100 bps = 1%)
GOLD_BUY_MARKUP_BPS=300
GOLD_SELL_DISCOUNT_BPS=200

# CORS — comma separated origins for web + Expo dev
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081,http://localhost:19006

# Referral bonus (paise — 5000 = ₹50)
REFERRAL_BONUS_PAISE=5000

# Razorpay — sign up at https://dashboard.razorpay.com (Test Mode is free)
# The Key ID is safe to expose to the client; the secret stays server-side.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
