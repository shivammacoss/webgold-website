# Expo + React Native ecosystems assume flat node_modules. pnpm's strict
# layout breaks plugin/peer resolution for several packages. Hoist everything.
node-linker=hoisted

# RN ecosystem packages frequently lag on peer-dep updates after a major
# React/RN bump. Without this flag, npm 7+ refuses installs whenever a
# transitive package hasn't yet declared support for the new React version.
legacy-peer-deps=true
